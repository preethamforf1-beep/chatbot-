# Backend Environment Variables

# Add your API keys and configuration here
# NEVER commit this file to version control!

# Server Configuration
PORT=5001
NODE_ENV=development

# OpenAI Configuration (Get your key from https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Database Configuration (if using real database later)
# DATABASE_URL=mongodb://localhost:27017/hrms

# SQL Server / MSSQL Configuration
# SQLSERVER_HOST=localhost
# SQLSERVER_PORT=1433
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=YourPassword123
# SQLSERVER_DATABASE=hrms
# SQLSERVER_ENCRYPT=false
# SQLSERVER_TRUST_CERT=true

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
